{
    "_description": "Simplified Flow Pipeline Configuration",
    "_version": "2.0",
    "_structure": "consolidated",
    "_note": "All stage configurations consolidated into single file",
    "dataset": {
        "source": "hub",
        "hub_id": "AiEDA/iPCL-R",
        "train_split": "train",
        "validation_split": "validation",
        "train_local_dir": "/mnt/local_data1/liujunfeng/exp/Medium-DecimalWordLevel/data_synthesis",
        "eval_local_dir": "/mnt/local_data1/liujunfeng/exp/Medium-DecimalWordLevel/stage_evaluation/evaluation_dataset"
    },
    "tokenization": {
        "paths": {
            "token_dataset_dir": "/mnt/local_data1/liujunfeng/exp/token_decimal_bpe/token_dataset",
            "tokenizer_save_dir": "/mnt/local_data1/liujunfeng/exp/token_decimal_bpe/tokenizer",
            "output_metadata_path": "/mnt/local_data1/liujunfeng/exp/token_decimal_bpe/output_metadata.json"
        },
        "workflow": {
            "tokenizer_algorithm": "DecimalBPE",
            "target_vocab_size": 1000,
            "max_sequence_length": 512,
            "save_metadata": true
        },
        "performance": {
            "num_workers": 32,
            "batch_size": 1000
        },
        "advanced": {
            "overlap_info_require": false,
            "overlap_top_k": 3,
            "connected_info_require": false,
            "connected_top_k": 3,
            "use_coord_sorted_input": true
        },
        "log_level": "INFO"
    },
    "training": {
        "paths": {
            "split_dataset_dir": "/mnt/local_data1/liujunfeng/exp/Medium-BPE/stage_training/split_dataset_geo",
            "model_save_dir": "/mnt/local_data1/liujunfeng/exp/Medium-BPE/stage_training/baseline",
            "logging_dir": "/mnt/local_data1/liujunfeng/exp/Medium-BPE/stage_training/baseline/logs"
        },
        "model": {
            "hidden_size": 512,
            "intermediate_size": 2048,
            "num_hidden_layers": 6,
            "num_attention_heads": 8,
            "num_key_value_heads": 4,
            "head_dim": 64,
            "max_position_embeddings": 256,
            "sliding_window": 128,
            "dropout_rate": 0.1,
            "geometric_config": {
                "use_advanced_geo_pe": false,
                "use_geo_self_attn": true,
                "use_geo_cross_attn": true,
                "coord_scale": 1e-3,
                "coord_scale_z": 1.0, 
                "num_frequencies": 32,
                "num_harmonics": 8,
                "max_wavelength": 10000.0,
                "min_wavelength": 1.0,
                "learnable_fourier_coefficients": false,
                "separate_sin_cos_basis": true,
                "floor_freq_ratio": 1.0,
                "max_sequence_length": 512,
                "max_metal_layers": 16,
                "max_layer_delta": 10,
                "pe_dropout": 0.1,
                "self_attn_geometric_bias": false,
                "cross_attn_geometric_bias": true,
                "use_value_rotation": true,
                "bias_num_freqs": 16,
                "bias_rank_per_head": 8,
                "coord_noise_enabled": false,
                "coord_noise_std_xy": 5.0,
                "coord_noise_std_z": 2.0,
                "coord_noise_max_ratio": 0.8,
                "coord_noise_warmup_steps": 5000,
                "coord_noise_cumulative": true
            }
        },
        "hyperparameters": {
            "quick_training": 1.0,
            "max_src_len": 128,
            "max_tgt_len": 256,
            "train_split_ratio": 0.9,
            "num_train_epochs": 100,
            "batch_size_per_device": 148,
            "gradient_accumulation_steps": 1,
            "learning_rate": 1e-4,
            "weight_decay": 0.005,
            "warmup_ratio": 0.05,
            "max_grad_norm": 1.0,
            "optimizer_type": "adafactor",
            "scheduler_type": "adafactor",
            "eval_strategy": "epoch",
            "save_strategy": "epoch",
            "early_stopping_patience": 3,
            "logging_strategy": "steps",
            "logging_steps": 50,
            "seed": 42
        },
        "performance": {
            "num_workers": 16,
            "batch_size": 1000,
            "dataloader_num_workers": 16,
            "dataloader_pin_memory": true,
            "resume_from_checkpoint": true
        },
        "log_level": "INFO"
    },
    "evaluation": {
        "paths": {
            "output_dir": "/mnt/local_data1/liujunfeng/exp/Medium-BPE/stage_evaluation/baseline",
            "metrics_dir": "/mnt/local_data1/liujunfeng/exp/Medium-BPE/stage_evaluation/baseline/metrics",
            "plots_dir": "/mnt/local_data1/liujunfeng/exp/Medium-BPE/stage_evaluation/baseline/plots",
            "logging_dir": "/mnt/local_data1/liujunfeng/exp/Medium-BPE/stage_evaluation/baseline/logs"
        },
        "generation": {
            "max_new_tokens": 512,
            "num_beams": 1,
            "do_sample": false,
            "temperature": 0.9,
            "top_p": 1.0,
            "top_k": 50,
            "repetition_penalty": 1.0,
            "length_penalty": 1.0,
            "early_stopping": true
        },
        "metrics": {
            "calculate_rouge": true,
            "calculate_bleu": true,
            "calculate_exact_match": true,
            "calculate_domain_metrics": true,
            "use_coordinate_parsing": true,
            "use_tree_structure_analysis": true,
            "use_routing_metrics": true
        },
        "performance": {
            "num_workers": 16,
            "batch_size": 32,
            "dataloader_num_workers": 16,
            "dataloader_pin_memory": true
        },
        "output": {
            "save_predictions": true,
            "save_metrics": true,
            "num_demo_examples": 5
        },
        "eval_designs": null,
        "log_level": "INFO"
    }
}

 
