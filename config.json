{
    "_description": "Simplified Flow Pipeline Configuration",
    "_version": "2.0",
    "_structure": "consolidated",
    "_note": "All stage configurations consolidated into single file",
    "dataset": {
        "source": "hub",
        "hub_id": "AiEDA/iPCL-R",
        "train_split": "train",
        "validation_split": "validation",
        "train_local_dir": "/mnt/local_data1/liujunfeng/exp/Medium-DecimalWordLevel/data_synthesis",
        "eval_local_dir": "/mnt/local_data1/liujunfeng/exp/Medium-DecimalWordLevel/stage_evaluation/evaluation_dataset"
    },
    "tokenization": {
        "paths": {
            "token_dataset_dir": "/mnt/local_data1/liujunfeng/exp/universal_token/token_dataset",
            "tokenizer_save_dir": "/mnt/local_data1/liujunfeng/exp/universal_token/tokenizer",
            "output_metadata_path": "/mnt/local_data1/liujunfeng/exp/universal_token/output_metadata.json"
        },
        "workflow": {
            "tokenizer_algorithm": "DecimalWordLevel",
            "target_vocab_size": 1000,
            "max_sequence_length": 512,
            "save_metadata": true
        },
        "performance": {
            "num_workers": 16,
            "batch_size": 1000
        },
        "advanced": {
            "overlap_info_require": false,
            "overlap_top_k": 3,
            "connected_info_require": false,
            "connected_top_k": 3,
            "use_coord_sorted_input": true
        },
        "log_level": "INFO"
    },
    "training": {
        "paths": {
            "split_dataset_dir": "/mnt/local_data1/liujunfeng/exp/Medium-GeoPE/stage_training/split_dataset",
            "model_save_dir": "/mnt/local_data1/liujunfeng/exp/Medium-GeoPE/stage_training/model",
            "logging_dir": "/mnt/local_data1/liujunfeng/exp/Medium-GeoPE/stage_training/logs"
        },
        "model": {
            "hidden_size": 512,
            "intermediate_size": 2048,
            "num_hidden_layers": 6,
            "num_attention_heads": 8,
            "num_key_value_heads": 4,
            "head_dim": 64,
            "max_position_embeddings": 256,
            "sliding_window": 128,
            "dropout_rate": 0.1,
            "geometric_config": {
                "use_basic_fourier_pe": false,
                "use_advanced_geo_pe": true,
                "use_metal_layer_only_pe":false,
                "use_geo_self_attn": true, 
                "use_geo_cross_attn": true, 
                "enable_encoder_lara": false,       
                "coord_scale": 1e-6,
                "num_frequencies": 32,
                "num_harmonics": 8,
                "max_wavelength": 10000.0,
                "min_wavelength": 1.0,
                "learnable_fourier_coefficients": false,
                "separate_sin_cos_basis": true,
                "floor_freq_ratio": 1.0,
                "max_sequence_length": 512,
                "max_metal_layers": 16,
                "max_layer_delta": 10,
                "pe_dropout": 0.1,
                "use_geometric_bias": true,
                "bias_mlp_hidden": 64,
                "use_vq": false,
                "vq_codebook_size": 512,
                "vq_commitment_cost": 0.25,
                "vq_ema_decay": 0.99, 
                "vq_dead_code_threshold":2 
            }
        },
        "hyperparameters": {
            "quick_training": 0.10,
            "max_src_len": 128,
            "max_tgt_len": 256,
            "train_split_ratio": 0.9,
            "num_train_epochs": 10,
            "batch_size_per_device": 96,
            "gradient_accumulation_steps": 1,
            "learning_rate": 0.0001,
            "weight_decay": 0.005,
            "warmup_ratio": 0.05,
            "max_grad_norm": 1.0,
            "optimizer_type": "adafactor",
            "scheduler_type": "adafactor",
            "eval_strategy": "epoch",
            "save_strategy": "epoch",
            "early_stopping_patience": 3,
            "logging_strategy": "steps",
            "logging_steps": 30,
            "seed": 42
        },
        "performance": {
            "num_workers": 16,
            "batch_size": 1000,
            "dataloader_num_workers": 16,
            "dataloader_pin_memory": true,
            "resume_from_checkpoint": false
        },
        "log_level": "INFO"
    },
    "evaluation": {
        "paths": {
            "output_dir": "/mnt/local_data1/liujunfeng/exp/Medium-DecimalWordLevel/stage_evaluation",
            "metrics_dir": "/mnt/local_data1/liujunfeng/exp/Medium-DecimalWordLevel/stage_evaluation/metrics",
            "plots_dir": "/mnt/local_data1/liujunfeng/exp/Medium-DecimalWordLevel/stage_evaluation/plots",
            "logging_dir": "/mnt/local_data1/liujunfeng/exp/Medium-DecimalWordLevel/stage_evaluation/logs"
        },
        "generation": {
            "max_new_tokens": 512,
            "num_beams": 1,
            "do_sample": false,
            "temperature": 0.9,
            "top_p": 1.0,
            "top_k": 50,
            "repetition_penalty": 1.0,
            "length_penalty": 1.0,
            "early_stopping": true
        },
        "metrics": {
            "calculate_rouge": true,
            "calculate_bleu": true,
            "calculate_exact_match": true,
            "calculate_domain_metrics": true,
            "use_coordinate_parsing": true,
            "use_tree_structure_analysis": true,
            "use_routing_metrics": true
        },
        "performance": {
            "num_workers": 16,
            "batch_size": 1,
            "dataloader_num_workers": 16,
            "dataloader_pin_memory": true
        },
        "output": {
            "save_predictions": true,
            "save_metrics": true,
            "num_demo_examples": 5
        },
        "log_level": "INFO"
    }
}

 